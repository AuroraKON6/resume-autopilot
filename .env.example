# DeepSeek API 配置
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Mimo / OpenAI-compatible vision API
OPENAI_API_KEY=your_mimo_or_openai_compatible_key_here
OPENAI_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5

# Optional local OCR model directory
EASYOCR_MODEL_DIR=C:\Users\your-user\.EasyOCR\model

# Python 路径
PYTHON_EXECUTABLE=python
